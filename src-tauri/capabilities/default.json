{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }, { "path": "/**" }]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{ "path": "**" }, { "path": "/**" }]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [{ "path": "**" }, { "path": "/**" }]
    },
    "dialog:default",
    "dialog:allow-open",
    "shell:default",
    "shell:allow-open",
    "http:default",
    {
      "identifier": "http:allow-fetch",
      "allow": [{ "url": "https://internal.slippi.gg/**" }]
    },
    "updater:default",
    "process:default"
  ]
}

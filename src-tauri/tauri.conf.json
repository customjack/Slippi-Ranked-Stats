{
  "productName": "Slippi Ranked Stats",
  "version": "1.2.3",
  "identifier": "com.slippi.rankedstats",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Slippi Ranked Stats",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYxREQxOTQzRjQ3RjUzRjAKUldUd1UzLzBReG5kWWFNZ0h1YTQzZXFTOVZ4OVBpaGwvalVpQ1lxNExVMnhZMmNqNnhoNUtSL28K",
      "endpoints": [
        "https://github.com/Joey-Farah/Slippi-Ranked-Stats/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
